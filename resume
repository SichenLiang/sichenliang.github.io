  <style>
    /* Ultra-clean, readable styling */
    body {
      margin: 0;
      padding: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      background-color: #525659; /* Standard dark PDF viewer background */
